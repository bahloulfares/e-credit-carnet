// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Énumération pour les rôles
enum UserRole {
  EPICIER
  SUPER_ADMIN
}

// Énumération pour le statut de l'abonnement
enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAUSED
  CANCELLED
}

// Énumération pour le type de transaction
enum TransactionType {
  CREDIT
  PAYMENT
}

// Énumération pour le statut de synchronisation
enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
}

// Table: Utilisateurs (Épiciers et Administrateurs)
model User {
  id                 String      @id @default(cuid())
  email              String      @unique
  firstName          String
  lastName           String
  password           String      // Hashé avec BCrypt
  phone              String?
  role               UserRole    @default(EPICIER)
  isActive           Boolean     @default(true)
  
  // Abonnement
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEndDate DateTime?
  trialStartDate     DateTime    @default(now())
  trialEndDate       DateTime?
  
  // Informations sur l'épicerie (optionnel pour super admin)
  shopName           String?
  shopAddress        String?
  shopPhone          String?
  
  // Données multi-tenant
  tenantId           String?     // Pour isolation client
  
  // Timestamps
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  
  // Relations
  clients            Client[]
  transactions       Transaction[]
  syncLogs           SyncLog[]
  
  @@index([email])
  @@index([role])
  @@index([subscriptionStatus])
}

// Table: Clients (debtors)
model Client {
  id                 String      @id @default(cuid())
  userId             String      // Référence à l'épicier propriétaire
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Informations personnelles
  firstName          String
  lastName           String
  phone              String?
  email              String?
  address            String?
  
  // Gestion des dettes
  totalDebt          Decimal     @default(0) @db.Decimal(12, 2)
  totalCredit        Decimal     @default(0) @db.Decimal(12, 2)
  totalPayment       Decimal     @default(0) @db.Decimal(12, 2)
  
  // Status
  isActive           Boolean     @default(true)
  status             String      @default("active") // active, suspended, deleted
  
  // Synchronisation
  syncStatus         SyncStatus  @default(SYNCED)
  lastSyncedAt       DateTime?
  
  // Timestamps
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?   // Soft delete
  
  // Relations
  transactions       Transaction[]
  
  @@unique([userId, id])
  @@index([userId])
  @@index([status])
  @@index([syncStatus])
}

// Table: Transactions (Crédits et Paiements)
model Transaction {
  id                 String      @id @default(cuid())
  userId             String      // Épicier propriétaire
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId           String      // Client concerné
  client             Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Type et montant
  type               TransactionType  // CREDIT ou PAYMENT
  amount             Decimal     @db.Decimal(12, 2)
  description        String?     // Détails de la transaction
  
  // Dates
  transactionDate    DateTime    @default(now())
  dueDate            DateTime?   // Date d'échéance pour les crédits
  
  // Paiements
  isPaid             Boolean     @default(false)
  paidAt             DateTime?
  paymentMethod      String?     // D17, Flouci, virement, espèces...
  
  // Synchronisation
  syncStatus         SyncStatus  @default(SYNCED)
  lastSyncedAt       DateTime?
  
  // Timestamps
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?   // Soft delete
  
  // Relations
  pendingSyncs       PendingSync[]
  
  @@index([userId])
  @@index([clientId])
  @@index([type])
  @@index([syncStatus])
  @@index([transactionDate])
}

// Table: PendingSync (Queue de synchronisation offline-first)
model PendingSync {
  id                 String      @id @default(cuid())
  userId             String      // Épicier propriétaire
  
  // Type d'opération
  entityType         String      // "client" ou "transaction"
  entityId           String      // ID du client ou transaction
  operationType      String      // "CREATE", "UPDATE", "DELETE"
  
  // Données à synchroniser
  data               Json        // Données complètes à synchroniser
  
  // Priorité et statut
  priority           Int         @default(0)
  retryCount         Int         @default(0)
  maxRetries         Int         @default(3)
  
  // Synchronisation
  syncStatus         SyncStatus  @default(PENDING)
  lastAttemptAt      DateTime?
  syncedAt           DateTime?
  
  // Relation optionnelle
  transactionId      String?
  transaction        Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  
  @@index([userId])
  @@index([syncStatus])
  @@index([entityType])
}

// Table: SyncLog (Historique des synchronisations)
model SyncLog {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Détails de la sync
  syncStartTime      DateTime    @default(now())
  syncEndTime        DateTime?
  status             String      // "success", "failure", "partial"
  
  // Statistiques
  itemsSynced        Int         @default(0)
  itemsFailed        Int         @default(0)
  errorMessage       String?
  
  // Métadonnées
  deviceInfo         String?     // Device type, OS, app version
  
  @@index([userId])
  @@index([syncStartTime])
}

// Table: AuditLog (Traçabilité pour conformité)
model AuditLog {
  id                 String      @id @default(cuid())
  userId             String?
  action             String      // "CREATE", "UPDATE", "DELETE", "LOGIN", etc
  entityType         String      // "user", "client", "transaction"
  entityId           String
  
  // Changements
  oldData            Json?
  newData            Json?
  
  // Métadonnées
  ipAddress          String?
  userAgent          String?
  
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  createdAt          DateTime    @default(now())
}

// Table: Backup (Gestion des backups)
model Backup {
  id                 String      @id @default(cuid())
  backupType         String      // "daily", "weekly", "manual"
  backupPath         String      // Chemin vers le fichier de backup
  backupSize         BigInt?     // Taille en bytes
  
  // Status
  status             String      // "success", "failure", "in_progress"
  errorMessage       String?
  
  // Timestamps
  backupDate         DateTime    @default(now())
  expiryDate         DateTime?   // Après 30 jours (conformité légale)
  
  @@index([backupType])
  @@index([backupDate])
}

// Table: Subscription (Gestion des abonnements)
model Subscription {
  id                 String      @id @default(cuid())
  userId             String      @unique
  
  // Détails abonnement
  plan               String      // "trial", "basic", "premium"
  startDate          DateTime    @default(now())
  endDate            DateTime
  autoRenew          Boolean     @default(true)
  
  // Paiement
  paymentMethod      String      // "d17", "flouci", "bank_transfer"
  lastPaymentDate    DateTime?
  nextPaymentDate    DateTime?
  
  // Tarification
  amountDT           Decimal     @db.Decimal(10, 2) // Montant en DT tunisiens
  
  // Timestamps
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  
  @@index([userId])
  @@index([endDate])
}

// Table: Support (Tickets de support)
model SupportTicket {
  id                 String      @id @default(cuid())
  userId             String
  
  // Détails du ticket
  subject            String
  description        String      @db.Text
  category           String      // "technical", "billing", "general"
  priority           String      // "low", "medium", "high", "critical"
  
  // Status
  status             String      @default("open") // open, in_progress, resolved, closed
  
  // Résolution
  response           String?     @db.Text
  resolvedAt         DateTime?
  
  // Timestamps
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([priority])
}
